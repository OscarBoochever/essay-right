{
  "name": "essayright-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:essayright": "npm run dev --workspace=apps/essayright",
    "dev:voiceright": "npm run dev --workspace=apps/voiceright",
    "build:essayright": "npm run build --workspace=apps/essayright",
    "build:voiceright": "npm run build --workspace=apps/voiceright"
  }
}
