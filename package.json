{
  "name": "essayright-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:essayright": "npm run dev --workspace=apps/essayright",
    "dev:proright": "npm run dev --workspace=apps/proright",
